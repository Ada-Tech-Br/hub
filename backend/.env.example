# Application
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=postgresql://ada:ada@localhost:5432/ada_platform

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# AWS (S3, SES, etc.)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
# Optional: SES API region if different from AWS_REGION
# SES_REGION=us-east-1
S3_BUCKET_NAME=ada-platform-files

# AWS CloudFront
CLOUDFRONT_DOMAIN=your-cloudfront-domain
CLOUDFRONT_KEY_ID=your-cloudfront-key-id
CLOUDFRONT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Email (Amazon SES) — EMAIL_FROM must be verified in SES (domain or address)
EMAIL_FROM=noreply@verified-domain.com

# Frontend URL
FRONTEND_URL=http://localhost:5173

# OTP
OTP_EXPIRE_MINUTES=10
