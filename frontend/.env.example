VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Ada Platform
VITE_GOOGLE_CLIENT_ID=your-google-client-id
# Same domains as backend GOOGLE_ALLOWED_EMAIL_DOMAINS (comma-separated).
# If exactly one domain, the login URL adds Google OAuth `hd` for the account picker.
VITE_GOOGLE_ALLOWED_EMAIL_DOMAINS=your-workspace-domain.com
